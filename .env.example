# Copy this file to .env and fill in your API key(s).
# Only one provider key is required; the others are optional.
# .env is in .gitignore — never commit the real file.

# ── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # default provider (Claude Haiku)
OPENAI_API_KEY=sk-...               # --provider openai (GPT-4o-mini)
GOOGLE_API_KEY=...                  # --provider google (Gemini Flash); pip install "buildocc[google]"

# ── Ollama (local, no key required) ──────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434 # default; change if Ollama runs elsewhere
# OLLAMA_MODEL=llama3.2              # default model; change to any pulled model
