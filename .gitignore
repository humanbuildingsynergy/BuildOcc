# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/
.env

# Data — datasets are large and have their own licenses; do not commit
data/atus/2019/raw/*
data/atus/2019/extracted/*
data/atus/2022/raw/*
data/atus/2022/extracted/*
data/atus/2023/raw/*
data/atus/2023/extracted/*
data/casas/*
data/ecobee/*
data/pecan_street/*
data/recs/*
# Keep codebook PDFs (small, reference-only, no redistribution restriction)
!data/atus/*/codebooks/*.pdf
!data/**/.gitkeep

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# IDE and tool caches
.vscode/
.idea/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db

# Simulation outputs and logs
outputs/
*.log
*.sqlite
*.db

# API keys / secrets
.env
*.env
secrets.toml

# Raw ATUS analysis outputs (regenerated from microdata via scripts/atus/analyze.py)
# Bundled defaults are in occupant_agent/data/ (tracked in git)
scripts/atus/outputs/

# Literature reading notes and bibliography — for manuscript use, not part of the software
references/

# In-progress manuscript — publish separately via journal / preprint
manuscript/

# Internal working documents (handoff notes)
docs/energyplus_handoff.md

# Validation experiment outputs (generated by scripts/validate_*.py)
scripts/experiments/outputs/

# LaTeX build artifacts
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.out
manuscript/*.spl
manuscript/*.synctex.gz

# EnergyPlus source ZIP — redundant (IDF and EPW committed individually)
examples/data/energyplus/*.zip
